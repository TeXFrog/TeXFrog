{
  "name": "texfrog",
  "displayName": "TeXFrog",
  "description": "Highlight game-based cryptographic proofs in LaTeX",
  "version": "0.1.0",
  "publisher": "texfrog",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:latex"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "texfrog.selectGame",
        "title": "TeXFrog: Select Game"
      },
      {
        "command": "texfrog.clearGame",
        "title": "TeXFrog: Clear Game Selection"
      }
    ],
    "keybindings": [
      {
        "command": "texfrog.selectGame",
        "key": "ctrl+k ctrl+g",
        "mac": "cmd+k cmd+g",
        "when": "editorLangId == latex"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
